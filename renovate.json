{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "timezone": "Europe/Warsaw",
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Group Spring Boot plugin updates.",
      "matchPackageNames": [
        "org.springframework.boot"
      ],
      "groupName": "Spring Boot"
    },
    {
      "description": "Keep Lombok compiler dependencies together.",
      "matchPackageNames": [
        "org.projectlombok:lombok"
      ],
      "groupName": "Lombok"
    }
  ]
}
