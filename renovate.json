{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "timezone": "Europe/Warsaw",
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Group Spring Boot plugin updates.",
      "matchPackageNames": [
        "org.springframework.boot"
      ],
      "groupName": "Spring Boot"
    },
    {
      "description": "Keep Lombok compiler dependencies together.",
      "matchPackageNames": [
        "org.projectlombok:lombok"
      ],
      "groupName": "Lombok"
    },
    {
      "description": "Group Jackson artifacts that release in sync.",
      "matchPackageNames": [
        "tools.jackson{/,}**",
        "com.fasterxml.jackson{/,}**"
      ],
      "groupName": "Jackson"
    },
    {
      "description": "Group Micrometer core + tracing + context-propagation.",
      "matchPackageNames": [
        "io.micrometer{/,}**"
      ],
      "groupName": "Micrometer"
    },
    {
      "description": "Group Project Reactor core + test + netty.",
      "matchPackageNames": [
        "io.projectreactor{/,}**",
        "io.projectreactor.netty{/,}**"
      ],
      "groupName": "Reactor"
    }
  ]
}
